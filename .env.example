# Common variables for all attestation types
PORT=3120
API_KEYS=12345

# TeeAvailabilityCheck
VERIFIER_TYPE=TeeAvailabilityCheck
SOURCE_ID=TEE
RELAY_CONTRACT_ADDRESS=
TEE_MACHINE_REGISTRY_CONTRACT_ADDRESS=
RPC_URL=  # Flare RPC
ALLOW_TEE_DEBUG=false # Enables debug mode for TEE. Only for test deployments.
DISABLE_ATTESTATION_CHECK_E2E=false # Disables attestation checks for E2E tests. Only for test deployments.
ALLOW_PRIVATE_NETWORKS=false # Allows private/loopback IPs while still blocking dangerous IPs and preserving DNS pinning.
MAX_POLLED_TEES=0 # Extension 0 TEEs are always polled. 0 = extension 0 only (default). >0 = also poll extra TEEs from other extensions, up to this total.

# PMWMultisigAccountConfigured
VERIFIER_TYPE=PMWMultisigAccountConfigured
SOURCE_ID=testXRP
RPC_URL= # Source RPC URL (i.e., testXRP, XRP)

# PMWPaymentStatus
VERIFIER_TYPE=PMWPaymentStatus
SOURCE_ID=testXRP
CCHAIN_DATABASE_URL= # Flare C-Chain indexer database
SOURCE_DATABASE_URL= # Source indexer database (i.e., testXRP, XRP)
TEE_INSTRUCTIONS_CONTRACT_ADDRESS= # Contract that emits TeeInstructionsSent events

# PMWFeeProof
VERIFIER_TYPE=PMWFeeProof
SOURCE_ID=testXRP
CCHAIN_DATABASE_URL= # Flare C-Chain indexer database
SOURCE_DATABASE_URL= # Source indexer database (i.e., testXRP, XRP)
TEE_INSTRUCTIONS_CONTRACT_ADDRESS= # Contract that emits TeeInstructionsSent events